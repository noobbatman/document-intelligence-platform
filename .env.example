# Docker Compose local defaults
# Copy this file to .env when you want to run the full stack locally with docker compose.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Document Intelligence Platform"
APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
PIPELINE_VERSION=0.3.1
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# ── Database / Redis (docker compose service names) ─────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/docintel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

REDIS_RATE_LIMIT_URL=redis://redis:6379/2

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports

# S3 / MinIO (only needed when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_UPLOADS=docintel-uploads
S3_BUCKET_EXPORTS=docintel-exports
S3_REGION=us-east-1

# ── OCR / pipeline ───────────────────────────────────────────────────────────
OCR_ENGINE=tesseract
SPACY_MODEL=en_core_web_sm
LOW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEYS=
API_KEY_HEADER=X-API-Key

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=30

# ── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10

# ── Optional integrations ────────────────────────────────────────────────────
LLM_EXTRACTION_ENABLED=false
LLM_UNKNOWN_EXTRACTION_ENABLED=true

# ── RAG (Retrieval-Augmented Generation) ────────────────────────────────────
RAG_ENABLED=false
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
EMBEDDING_MODEL=models/text-embedding-004

EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX
EMAIL_MAX_ATTACHMENTS_PER_RUN=50
