# Docker Compose defaults — copy to .env and fill in your values.
# Required: only GEMINI_API_KEY. Everything else has a sensible default.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Document Intelligence Platform"
APP_ENV=local
DEBUG=false
LOG_LEVEL=INFO
PIPELINE_VERSION=0.3.1
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=*

# ── Database / Redis (docker compose service names) ─────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/docintel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

REDIS_RATE_LIMIT_URL=redis://redis:6379/2

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports

# S3 / MinIO (only needed when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_UPLOADS=docintel-uploads
S3_BUCKET_EXPORTS=docintel-exports
S3_REGION=us-east-1

# ── OCR / pipeline ───────────────────────────────────────────────────────────
OCR_ENGINE=tesseract
OCR_PREPROCESS=true
OCR_DESKEW=true
OCR_DENOISE=true
OCR_ENHANCE_CONTRAST=true
OCR_ENGINE_PRIMARY=tesseract
PDF_RENDER_ZOOM=3.0
HANDWRITING_CONFIDENCE_THRESHOLD=0.70
SPACY_MODEL=en_core_web_sm
LOW_CONFIDENCE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_MB=50

# ── LLM — REQUIRED for draft generation and preference learning ───────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: enable Anthropic-backed extraction for unknown document types
# Requires ANTHROPIC_API_KEY to be set in the environment separately.
LLM_EXTRACTION_ENABLED=false
LLM_UNKNOWN_EXTRACTION_ENABLED=true

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=32

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE_CHARS=600
CHUNK_OVERLAP_CHARS=120
SECTION_DETECTION_ENABLED=true

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.35

# ── Draft generation ──────────────────────────────────────────────────────────
DRAFT_MODEL=gemini-2.5-flash
DRAFT_MAX_CHUNKS=10
DRAFT_MAX_TOKENS=8192

# ── Preference learning ───────────────────────────────────────────────────────
PREFERENCE_DEDUP_THRESHOLD=0.85
PREFERENCE_MAX_PER_DRAFT=5

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEYS=
API_KEY_HEADER=X-API-Key

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT_SECONDS=10
